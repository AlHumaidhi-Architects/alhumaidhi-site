# ── Admin editor ───────────────────────────────────────────────────────────
# Password for the /admin dashboard. Choose something strong.
ADMIN_PASSWORD=change-me

# Optional — extra secret mixed into the session cookie. Any random string.
# ADMIN_SESSION_SECRET=some-long-random-string

# ── Supabase (stores the editable content + uploaded images) ──────────────
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# One-time Supabase setup:
#   1. SQL editor → run:
#        create table if not exists site_content (
#          id int primary key default 1,
#          data jsonb not null default '{}'::jsonb,
#          updated_at timestamptz not null default now()
#        );
#   2. (Optional, for image uploads) Storage → create a PUBLIC bucket named: site-media
#
# Copy this file to .env.local and fill in the values, then restart `npm run dev`.
